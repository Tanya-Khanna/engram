# Qwen Cloud / DashScope — pay-as-you-go `sk-` key (NOT a Token Plan `sk-sp-` key;
# Token Plan scope excludes backend scripts and throws 401 InvalidApiKey).
DASHSCOPE_API_KEY=sk-your-key-here

# Demo site version switch (v1 | v2) — the staleness demo flips this.
SKYFINDER_VERSION=v1

# Qdrant (docker-compose service)
QDRANT_URL=http://localhost:6333
